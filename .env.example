# --- Base de données ---
POSTGRES_USER=trafficguard
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=trafficguard
DATABASE_URL=postgresql://trafficguard:change-me-in-prod@localhost:5432/trafficguard?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-super-secret-in-prod
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-me-refresh-secret-in-prod
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# --- Services ---
API_PORT=3001
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_PORT=8000
WEB_PORT=3000

# --- Stockage images (S3-compatible, MinIO en local) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=trafficguard-captures
S3_REGION=us-east-1

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# --- Clé de service machine-à-machine (worker flux vidéo ML -> API) ---
SERVICE_API_KEY=change-me

# --- Pipeline flux vidéo ML (détection mouvement -> véhicule -> plaque) ---
# Cadence d'analyse d'une frame (secondes) et anti-doublon par plaque.
STREAM_SAMPLE_INTERVAL=2.0
STREAM_PLATE_COOLDOWN=60.0
STREAM_MIN_CONFIDENCE=0.5
STREAM_MAX_CONCURRENT=20
# Gate 1 — mouvement : surface minimale de mouvement (fraction de la frame).
MOTION_MIN_AREA_RATIO=0.01
# Gate 2 — véhicule (heuristique) : surface min et fourchette de ratio l/h.
VEHICLE_MIN_AREA_RATIO=0.02
VEHICLE_MIN_ASPECT=0.7
VEHICLE_MAX_ASPECT=6.0
# Optionnel : détecteur véhicules deep learning (nécessite `ultralytics`).
# VEHICLE_MODEL=yolov8n.pt
